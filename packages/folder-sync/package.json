{
  "name": "@shivbijlani/folder-sync",
  "version": "0.0.1",
  "description": "Local-first folder sync engine with pluggable cloud providers and a service-worker backend.",
  "type": "module",
  "private": true,
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
